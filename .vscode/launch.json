{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Gemma-San (debug, physical device)",
      "request": "launch",
      "type": "dart",
      "args": [
        "--dart-define=HF_TOKEN=${env:HF_TOKEN}"
      ]
    },
    {
      "name": "Gemma-San (profile)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "profile",
      "args": [
        "--dart-define=HF_TOKEN=${env:HF_TOKEN}"
      ]
    }
  ]
}
