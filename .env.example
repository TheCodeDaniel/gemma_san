# Get a token at https://huggingface.co/settings/tokens
# Accept the model licence: https://huggingface.co/litert-community/gemma-4-E4B-it-litert-lm
HF_TOKEN=hf_replace_me
# false = CPU backend (works on emulator + all real devices, slower inference)
# true  = GPU backend (real device only — crashes on emulator SwiftShader)
USE_GPU=false
